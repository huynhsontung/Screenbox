<Page
    x:Class="Screenbox.Pages.PlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Screenbox.Behaviors"
    xmlns:commands="using:Screenbox.Commands"
    xmlns:controls="using:Screenbox.Controls"
    xmlns:ctAnimations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="using:Screenbox.Extensions"
    xmlns:helpers="using:Screenbox.Helpers"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:Screenbox.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:primitives="using:Windows.UI.Xaml.Controls.Primitives"
    xmlns:strings="using:Screenbox.Strings"
    xmlns:templates="using:Screenbox.Templates"
    xmlns:triggers="using:CommunityToolkit.WinUI"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewModels="using:Screenbox.Core.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/CommandBar.xaml" />
                <templates:GridViewItemTemplates />
            </ResourceDictionary.MergedDictionaries>

            <MenuFlyout x:Key="ItemFlyout">
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Text="{x:Bind strings:Resources.Play}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon FontFamily="{StaticResource ScreenboxSymbolThemeFontFamily}" Glyph="{StaticResource PlayGlyph}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayNextCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayAddGlyph}}"
                    Text="{strings:Resources Key=PlayNext}" />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.AddToQueueCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Text="{x:Bind strings:Resources.AddToQueue}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon
                            x:Name="AddToQueueMenuFlyoutItemIcon"
                            FontFamily="{StaticResource ScreenboxSymbolThemeFontFamily}"
                            Glyph="{StaticResource PlaylistMusicAddGlyph}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Command="{x:Bind RenamePlaylistCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Icon="{ui:SymbolIcon Symbol=Rename}"
                    Text="{strings:Resources Key=Rename}" />
                <MenuFlyoutItem
                    Command="{x:Bind ExportPlaylistCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Text="{strings:Resources Key=Export}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xEDE1;" MirroredWhenRightToLeft="True" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    Command="{x:Bind DeletePlaylistCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Icon="{ui:SymbolIcon Symbol=Delete}"
                    Text="{strings:Resources Key=Delete}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.Selection.SelectItemCommand}"
                    CommandParameter="{x:Bind ViewModel.ContextPlaylist, Mode=OneWay}"
                    Text="{x:Bind strings:Resources.Select}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon
                            x:Name="SelectMenuFlyoutItemIcon"
                            FontFamily="{StaticResource ScreenboxSymbolThemeFontFamily}"
                            Glyph="{StaticResource SingleSelectGlyph}" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>

            <MenuFlyout x:Key="CreatePlaylistFlyout" Placement="{x:Bind helpers:GlobalizationHelper.MirrorWhenRightToLeft(primitives:FlyoutPlacementMode.BottomEdgeAlignedRight)}">
                <MenuFlyoutItem Command="{x:Bind ViewModel.ImportPlaylistCommand}" Text="{x:Bind strings:Resources.ImportPlaylist}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8B5;" MirroredWhenRightToLeft="True" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            MinHeight="{StaticResource PageHeaderMinHeight}"
            Margin="{StaticResource BottomMediumMargin}"
            Padding="{StaticResource ContentPagePadding}">
            <TextBlock
                Style="{StaticResource TitleMediumTextBlockStyle}"
                Text="{strings:Resources Key=Playlists}"
                TextWrapping="NoWrap">
                <interactivity:Interaction.Behaviors>
                    <behaviors:OverflowTextToolTipBehavior />
                </interactivity:Interaction.Behaviors>
            </TextBlock>
        </Grid>

        <Grid
            x:Name="SubHeaderGrid"
            Grid.Row="1"
            MinHeight="{StaticResource PageHeaderMinHeight}"
            Margin="0,0,0,8"
            Padding="{StaticResource ContentPagePadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="SubHeaderCreateButton"
                Grid.Column="0"
                AutomationProperties.Name="{x:Bind strings:Resources.NewPlaylist}"
                Command="{x:Bind CreatePlaylistCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Margin="{StaticResource IconButtonStandardIconMargin}" Glyph="&#xE710;" />
                    <TextBlock Margin="8,0,0,0" Text="{x:Bind strings:Resources.NewPlaylist}" />
                </StackPanel>
            </Button>

            <Button
                x:Name="SubHeaderImportButton"
                Grid.Column="1"
                AutomationProperties.Name="{x:Bind strings:Resources.ImportPlaylist}"
                Command="{x:Bind ViewModel.ImportPlaylistCommand}">
                <StackPanel Orientation="Horizontal">
                    <FontIcon
                        Margin="{StaticResource IconButtonStandardIconMargin}"
                        Glyph="&#xE8B5;"
                        MirroredWhenRightToLeft="True" />
                    <TextBlock
                        x:Name="SubHeaderImportButtonText"
                        Margin="8,0,0,0"
                        Text="{x:Bind strings:Resources.ImportPlaylist}" />
                </StackPanel>
            </Button>

            <controls:SelectionBarControl
                x:Name="SelectionBar"
                Grid.ColumnSpan="2"
                ctAnimations:Implicit.ShowAnimations="{StaticResource SelectionBarEntranceImplicitAnimation}"
                AddToQueueButtonCommand="{x:Bind ViewModel.AddSelectedToQueueCommand}"
                CheckBoxCommand="{StaticResource SelectDeselectAllCommand}"
                CheckBoxCommandParameter="{x:Bind PlaylistsGridView}"
                CheckBoxIsChecked="{x:Bind ViewModel.Selection.IsAllSelected, Mode=OneWay}"
                CheckBoxText="{x:Bind strings:Resources.PlaylistsSelected(ViewModel.Selection.SelectedItems.Count), Mode=OneWay}"
                CloseButtonCommand="{x:Bind ViewModel.Selection.ClearSelectionCommand}"
                CommandParameter="{x:Bind PlaylistsGridView.SelectedItems}"
                IsAddToPlaylistButtonVisible="False"
                IsRemoveButtonVisible="False"
                PlayButtonCommand="{x:Bind ViewModel.PlaySelectedCommand}"
                PlayNextButtonCommand="{x:Bind ViewModel.PlaySelectedNextCommand}"
                Visibility="Collapsed">
                <controls:SelectionBarControl.AdditionalCommands>
                    <AppBarButton
                        Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                        CommandParameter="{x:Bind PlaylistsGridView.SelectedItems}"
                        Icon="Delete"
                        Label="{x:Bind strings:Resources.Delete}">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Delete" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </controls:SelectionBarControl.AdditionalCommands>
            </controls:SelectionBarControl>
        </Grid>

        <GridView
            x:Name="PlaylistsGridView"
            Grid.Row="2"
            Margin="{StaticResource TopMediumMargin}"
            Padding="{StaticResource GridViewContentPagePadding}"
            ui:ListViewExtensions.Command="{x:Bind Common.OpenPlaylistCommand}"
            ui:ScrollViewerExtensions.VerticalScrollBarMargin="{x:Bind Common.ScrollBarMargin, Mode=OneWay}"
            IsItemClickEnabled="True"
            ItemContainerStyle="{StaticResource GridViewItemMediaCardStyle}"
            ItemTemplate="{StaticResource PlaylistGridViewItemTemplate}"
            ItemsSource="{x:Bind ViewModel.Playlists}"
            KeyboardAcceleratorPlacementMode="Hidden"
            SelectionMode="Extended">
            <GridView.Resources>
                <commands:BindableCommand x:Key="MediaListViewItemPlayCommand" Command="{x:Bind ViewModel.PlayCommand}" />
            </GridView.Resources>
            <GridView.KeyboardAccelerators>
                <KeyboardAccelerator
                    Key="A"
                    Invoked="SelectDeselectAllKeyboardAccelerator_OnInvoked"
                    Modifiers="Control" />
            </GridView.KeyboardAccelerators>
            <GridView.Footer>
                <Border Height="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
            </GridView.Footer>
            <interactivity:Interaction.Behaviors>
                <behaviors:ListViewContextBehavior ContextItem="{x:Bind ViewModel.ContextPlaylist, Mode=TwoWay}" Flyout="{StaticResource ItemFlyout}" />
                <behaviors:ListViewSelectionBehavior SelectedItems="{x:Bind ViewModel.Selection.SelectedItems}" />
            </interactivity:Interaction.Behaviors>
        </GridView>

        <!--  Empty playlists  -->
        <ScrollViewer
            x:Name="NoPlaylistsViewer"
            Grid.Row="2"
            Margin="{x:Bind Common.FooterBottomPaddingMargin, Mode=OneWay}"
            Padding="{StaticResource ContentPagePadding}"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            Visibility="Collapsed">
            <controls:ContentUnavailableView
                x:Name="NoPlaylistsPanel"
                Title="{x:Bind strings:Resources.NoPlaylistsPanelHeader}"
                IsOpen="False"
                Message="{x:Bind strings:Resources.NoPlaylistsPanelSubtext}">
                <FontIcon
                    x:Name="NoPlaylistsPanelIcon"
                    Margin="0,0,16,0"
                    FontFamily="{StaticResource ScreenboxSymbolThemeFontFamily}"
                    FontSize="{StaticResource NoContentPanelIconFontSize}"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="{StaticResource PlaylistOffGlyph}" />
                <controls:ContentUnavailableView.ActionContent>
                    <muxc:SplitButton
                        extensions:SplitButtonExtensions.SecondaryButtonAccessKey="{x:Bind strings:KeyboardResources.CommandMoreOptionsKey}"
                        AccessKey="{x:Bind strings:KeyboardResources.CommandAddOpenFilesKey}"
                        AutomationProperties.HelpText="{x:Bind strings:Resources.OpenFilesToolTip}"
                        AutomationProperties.Name="{x:Bind strings:Resources.NewPlaylist}"
                        Command="{x:Bind CreatePlaylistCommand}"
                        Flyout="{StaticResource CreatePlaylistFlyout}"
                        Style="{StaticResource AccentSplitButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Margin="{StaticResource IconButtonStandardIconMargin}" Glyph="&#xE710;" />
                            <TextBlock Margin="8,0,0,0" Text="{strings:Resources Key=NewPlaylist}" />
                        </StackPanel>
                        <interactivity:Interaction.Behaviors>
                            <behaviors:SplitButtonXYNavigationBehavior />
                        </interactivity:Interaction.Behaviors>
                    </muxc:SplitButton>
                </controls:ContentUnavailableView.ActionContent>
            </controls:ContentUnavailableView>
        </ScrollViewer>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="NavigationViewStates">
                <VisualState x:Name="Expanded" />
                <VisualState x:Name="Compact" />
                <VisualState x:Name="Minimal">
                    <VisualState.StateTriggers>
                        <triggers:IsEqualStateTrigger Value="{x:Bind Common.NavigationViewDisplayMode, Mode=OneWay}" To="{StaticResource MinimalNavigationViewDisplayMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="SubHeaderGrid.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="SubHeaderImportButton.(ToolTipService.ToolTip)" Value="{x:Bind strings:Resources.ImportPlaylist}" />
                        <Setter Target="SubHeaderImportButtonText.Visibility" Value="Collapsed" />
                        <Setter Target="PlaylistsGridView.Padding" Value="{StaticResource GridViewContentPageMinimalPadding}" />
                        <Setter Target="NoPlaylistsViewer.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="NoPlaylistsPanelIcon.Margin" Value="0,0,0,0" />
                        <Setter Target="NoPlaylistsPanelIcon.FontSize" Value="{StaticResource NoContentPanelMinimalIconFontSize}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="ContentStates">
                <VisualState x:Name="PlaylistsEmpty">
                    <VisualState.StateTriggers>
                        <triggers:IsNullOrEmptyStateTrigger Value="{x:Bind ViewModel.Playlists, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SubHeaderGrid.Visibility" Value="Collapsed" />
                        <Setter Target="PlaylistsGridView.Visibility" Value="Collapsed" />
                        <Setter Target="NoPlaylistsViewer.Visibility" Value="Visible" />
                        <Setter Target="NoPlaylistsPanel.IsOpen" Value="True" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="SelectionStates">
                <VisualState x:Name="ExtendedSelection" />
                <VisualState x:Name="MultipleSelection">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.Selection.IsSelectionModeActive, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SubHeaderCreateButton.Visibility" Value="Collapsed" />
                        <Setter Target="SubHeaderImportButton.Visibility" Value="Collapsed" />
                        <Setter Target="SelectionBar.Visibility" Value="Visible" />
                        <Setter Target="PlaylistsGridView.SelectionMode" Value="Multiple" />
                        <Setter Target="PlaylistsGridView.IsItemClickEnabled" Value="False" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="FlowDirectionStates">
                <VisualState x:Name="RightToLeft">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind helpers:GlobalizationHelper.IsRightToLeftLanguage}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SelectMenuFlyoutItemIcon.Glyph" Value="{StaticResource SingleSelectMirroredGlyph}" />
                        <Setter Target="AddToQueueMenuFlyoutItemIcon.Glyph" Value="{StaticResource PlaylistMusicAddMirroredGlyph}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
