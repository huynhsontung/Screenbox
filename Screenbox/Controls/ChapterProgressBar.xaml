<UserControl
    x:Class="Screenbox.Controls.ChapterProgressBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Screenbox.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:viewModels="using:Screenbox.Core.ViewModels"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/Progress.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ItemsControl ItemsSource="{x:Bind ProgressItems}">
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="viewModels:ChapterViewModel">
                <muxc:ProgressBar
                    Width="{x:Bind Width, Mode=OneWay}"
                    Maximum="{x:Bind Maximum, Mode=OneWay}"
                    Minimum="{x:Bind Minimum, Mode=OneWay}"
                    Style="{StaticResource ChapterProgressBarStyle}"
                    Value="{x:Bind Value, Mode=OneWay}" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="1" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>
</UserControl>
