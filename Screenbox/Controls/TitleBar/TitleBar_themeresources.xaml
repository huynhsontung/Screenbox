<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Screenbox.Controls">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!--  Caption button foreground alpha is ignored, colors are flattened into opaque brushes.  -->
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#FFFFFF" />
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonHoverForegroundBrush" Color="#FFFFFF" />
            <!--  TextFillColorSecondary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonPressedForegroundBrush" Color="#CFCFCF" />
            <!--  TextFillColorTertiary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonInactiveForegroundBrush" Color="#717171" />

            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SubtleFillColorDisabledBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="TitleBarButtonForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="TitleBarButtonHoverForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="TitleBarButtonPressedForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="TitleBarButtonInactiveForegroundBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <!--  Caption button foreground alpha is ignored, colors are flattened into opaque brushes.  -->
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#191919" />
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonHoverForegroundBrush" Color="#191919" />
            <!--  TextFillColorSecondary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonPressedForegroundBrush" Color="#606060" />
            <!--  TextFillColorTertiary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonInactiveForegroundBrush" Color="#9B9B9B" />

            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SubtleFillColorDisabledBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="TitleBarButtonForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="TitleBarButtonHoverForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="TitleBarButtonPressedForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="TitleBarButtonInactiveForegroundBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="SystemColorButtonFaceColorBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="TitleBarStandardHeight">32</x:Double>
    <x:Double x:Key="TitleBarTallHeight">48</x:Double>

    <x:Double x:Key="TitleBarIconMaxWidth">16</x:Double>
    <x:Double x:Key="TitleBarIconMaxHeight">16</x:Double>
    <Thickness x:Key="TitleBarIconMargin">16,0,16,0</Thickness>
    <Thickness x:Key="TitleBarHeaderIconMargin">0,0,16,0</Thickness>

    <Thickness x:Key="TitleBarTitleMargin">0,0,8,2</Thickness>
    <OpticalMarginAlignment x:Key="TitleBarTitleOpticalMarginAlignment">TrimSideBearings</OpticalMarginAlignment>

    <HorizontalAlignment x:Key="TitleBarHeaderHorizontalAlignment">Left</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarHeaderVerticalAlignment">Center</VerticalAlignment>
    <HorizontalAlignment x:Key="TitleBarContentHorizontalAlignment">Center</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarContentVerticalAlignment">Center</VerticalAlignment>
    <HorizontalAlignment x:Key="TitleBarFooterHorizontalAlignment">Right</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarFooterVerticalAlignment">Center</VerticalAlignment>

</ResourceDictionary>
