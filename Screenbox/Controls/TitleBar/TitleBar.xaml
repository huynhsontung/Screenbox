<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Screenbox.Controls"
    xmlns:local="using:Screenbox">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!--  Caption button foreground alpha is ignored, colors are flattened into opaque brushes.  -->
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#FFFFFF" />
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonHoverForegroundBrush" Color="#FFFFFF" />
            <!--  TextFillColorSecondary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonPressedForegroundBrush" Color="#CFCFCF" />
            <!--  TextFillColorTertiary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonInactiveForegroundBrush" Color="#717171" />

            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SubtleFillColorDisabledBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="TitleBarButtonForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="TitleBarButtonHoverForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="TitleBarButtonPressedForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="TitleBarButtonInactiveForegroundBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <!--  Caption button foreground alpha is ignored, colors are flattened into opaque brushes.  -->
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#191919" />
            <!--  TextFillColorPrimary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonHoverForegroundBrush" Color="#191919" />
            <!--  TextFillColorSecondary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonPressedForegroundBrush" Color="#606060" />
            <!--  TextFillColorTertiary over SolidBackgroundFillColorBase  -->
            <SolidColorBrush x:Key="TitleBarButtonInactiveForegroundBrush" Color="#9B9B9B" />

            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SubtleFillColorTransparentBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SubtleFillColorDisabledBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="TitleBarButtonForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="TitleBarButtonHoverForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="TitleBarButtonPressedForegroundBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="TitleBarButtonInactiveForegroundBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="TitleBarCaptionButtonBackground" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPointerOver" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonBackgroundDisabled" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForeground" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPointerOver" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="TitleBarCaptionButtonForegroundDisabled" ResourceKey="SystemColorButtonFaceColorBrush" />

            <StaticResource x:Key="TitleBarForeground" ResourceKey="TextFillColorPrimaryBrush" />
            <StaticResource x:Key="TitleBarForegroundDeactivated" ResourceKey="TextFillColorTertiaryBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="TitleBarStandardHeight">32</x:Double>
    <x:Double x:Key="TitleBarTallHeight">48</x:Double>

    <x:Double x:Key="TitleBarIconMaxWidth">16</x:Double>
    <x:Double x:Key="TitleBarIconMaxHeight">16</x:Double>
    <Thickness x:Key="TitleBarIconMargin">16,0,16,0</Thickness>
    <Thickness x:Key="TitleBarHeaderIconMargin">0,0,16,0</Thickness>

    <Thickness x:Key="TitleBarTitleMargin">0,0,8,2</Thickness>
    <OpticalMarginAlignment x:Key="TitleBarTitleOpticalMarginAlignment">TrimSideBearings</OpticalMarginAlignment>

    <HorizontalAlignment x:Key="TitleBarHeaderHorizontalAlignment">Left</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarHeaderVerticalAlignment">Center</VerticalAlignment>
    <HorizontalAlignment x:Key="TitleBarContentHorizontalAlignment">Center</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarContentVerticalAlignment">Center</VerticalAlignment>
    <HorizontalAlignment x:Key="TitleBarFooterHorizontalAlignment">Right</HorizontalAlignment>
    <VerticalAlignment x:Key="TitleBarFooterVerticalAlignment">Center</VerticalAlignment>

    <Style BasedOn="{StaticResource DefaultTitleBarStyle}" TargetType="controls:TitleBar" />

    <Style x:Key="DefaultTitleBarStyle" TargetType="controls:TitleBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="CaptionButtonBackgroundBrush" Value="{ThemeResource TitleBarCaptionButtonBackground}" />
        <Setter Property="CaptionButtonBackgroundPointerOverBrush" Value="{ThemeResource TitleBarCaptionButtonBackgroundPointerOver}" />
        <Setter Property="CaptionButtonBackgroundPressedBrush" Value="{ThemeResource TitleBarCaptionButtonBackgroundPressed}" />
        <Setter Property="CaptionButtonBackgroundInactiveBrush" Value="{ThemeResource TitleBarCaptionButtonBackgroundDisabled}" />
        <Setter Property="CaptionButtonForegroundBrush" Value="{ThemeResource TitleBarCaptionButtonForeground}" />
        <Setter Property="CaptionButtonForegroundPointerOverBrush" Value="{ThemeResource TitleBarCaptionButtonForegroundPointerOver}" />
        <Setter Property="CaptionButtonForegroundPressedBrush" Value="{ThemeResource TitleBarCaptionButtonForegroundPressed}" />
        <Setter Property="CaptionButtonForegroundInactiveBrush" Value="{ThemeResource TitleBarCaptionButtonForegroundDisabled}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TitleBar">
                    <Grid
                        x:Name="LayoutRoot"
                        MinHeight="{ThemeResource TitleBarStandardHeight}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LeftPaddingColumn" Width="0" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <!--  Icon and Title placed before the DragRegion to enable dragging.  -->
                        <Viewbox
                            x:Name="Icon"
                            Grid.Column="2"
                            MaxWidth="{ThemeResource TitleBarIconMaxWidth}"
                            MaxHeight="{ThemeResource TitleBarIconMaxHeight}"
                            Margin="{ThemeResource TitleBarIconMargin}"
                            VerticalAlignment="Center"
                            Child="{TemplateBinding Icon}" />

                        <TextBlock
                            x:Name="TitleTextBlock"
                            Grid.Column="3"
                            Margin="{ThemeResource TitleBarTitleMargin}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TitleBarForeground}"
                            OpticalMarginAlignment="{ThemeResource TitleBarTitleOpticalMarginAlignment}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{TemplateBinding Title}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />

                        <Grid
                            x:Name="DragRegion"
                            Grid.Column="0"
                            Grid.ColumnSpan="7"
                            Background="Transparent" />

                        <ContentPresenter
                            x:Name="HeaderContentPresenter"
                            Grid.Column="1"
                            HorizontalAlignment="{ThemeResource TitleBarHeaderHorizontalAlignment}"
                            VerticalAlignment="{ThemeResource TitleBarHeaderVerticalAlignment}"
                            x:DeferLoadStrategy="Lazy"
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            ContentTransitions="{TemplateBinding HeaderTransitions}"
                            Visibility="Collapsed" />

                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Grid.Column="4"
                            HorizontalAlignment="{ThemeResource TitleBarContentHorizontalAlignment}"
                            VerticalAlignment="{ThemeResource TitleBarContentVerticalAlignment}"
                            x:DeferLoadStrategy="Lazy"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            Visibility="Collapsed" />

                        <ContentPresenter
                            x:Name="FooterContentPresenter"
                            Grid.Column="5"
                            HorizontalAlignment="{ThemeResource TitleBarFooterHorizontalAlignment}"
                            VerticalAlignment="{ThemeResource TitleBarFooterVerticalAlignment}"
                            x:DeferLoadStrategy="Lazy"
                            Content="{TemplateBinding Footer}"
                            ContentTemplate="{TemplateBinding FooterTemplate}"
                            ContentTransitions="{TemplateBinding FooterTransitions}"
                            Visibility="Collapsed" />

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="ActivationStateGroup">
                                <VisualState x:Name="Activated" />
                                <VisualState x:Name="Deactivated">
                                    <VisualState.Setters>
                                        <Setter Target="TitleTextBlock.Foreground" Value="{ThemeResource TitleBarForegroundDeactivated}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="SizeGroup">
                                <VisualState x:Name="Standard" />
                                <VisualState x:Name="Tall">
                                    <VisualState.Setters>
                                        <Setter Target="LayoutRoot.MinHeight" Value="{ThemeResource TitleBarTallHeight}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <!--<VisualStateGroup x:Name="FullScreenGroup">
                                <VisualState x:Name="TitleBarVisible" />
                                <VisualState x:Name="TitleBarCollapsed">
                                    <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>-->

                            <VisualStateGroup x:Name="HeaderVisibilityGroup">
                                <VisualState x:Name="HeaderCollapsed" />
                                <VisualState x:Name="HeaderVisible">
                                    <VisualState.Setters>
                                        <Setter Target="HeaderContentPresenter.Visibility" Value="Visible" />
                                        <Setter Target="Icon.Margin" Value="{ThemeResource TitleBarHeaderIconMargin}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="IconVisibilityGroup">
                                <VisualState x:Name="IconVisible" />
                                <VisualState x:Name="IconCollapsed">
                                    <VisualState.Setters>
                                        <Setter Target="Icon.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="TitleVisibilityGroup">
                                <VisualState x:Name="TitleVisible" />
                                <VisualState x:Name="TitleCollapsed">
                                    <VisualState.Setters>
                                        <Setter Target="TitleTextBlock.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="ContentGroup">
                                <VisualState x:Name="ContentCollapsed" />
                                <VisualState x:Name="ContentVisible">
                                    <VisualState.Setters>
                                        <Setter Target="ContentPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="FooterVisibilityGroup">
                                <VisualState x:Name="FooterCollapsed" />
                                <VisualState x:Name="FooterVisible">
                                    <VisualState.Setters>
                                        <Setter Target="FooterContentPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
